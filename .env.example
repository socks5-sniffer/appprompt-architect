# Copy this file to .env and fill in your keys.
# The server reads these at startup - keys are NEVER sent to the browser.

# Google Gemini API key (required to use Gemini provider)
GEMINI_API_KEY=

# Anthropic Claude API key (required to use Claude provider)
ANTHROPIC_API_KEY=

# OpenAI API key (required to use OpenAI provider)
OPENAI_API_KEY=

# Port for the backend API server (default: 3001)
PORT=3001

# Frontend origin for CORS (default: http://localhost:3000)
FRONTEND_URL=http://localhost:3000
